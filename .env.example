# Optional: SQLite path (default ./data/aura.db). Use persistent disk on your host if needed.
# DATABASE_PATH=./data/aura.db

# Optional: POST JSON payloads when an email is detected in a customer message (Slack/Zapier/custom endpoint).
# LEAD_NOTIFY_WEBHOOK_URL=

# Optional: Graph API version segment (default v21.0)
# GRAPH_API_VERSION=v21.0

# After 24h since the customer's last user message, send this approved template instead of calling Gemini.
# WA_REENGAGEMENT_TEMPLATE=reengagement_ping
# (Alias: WA_REENGAGEMENT_TEMPLATES — same value, if your checklist uses the plural name.)
# WA_TEMPLATE_LANG=en_US

# Dev only: skip X-Hub-Signature-256 verification (never use in production).
# SKIP_WEBHOOK_SIGNATURE=1

# Optional: override default (83)
# INR_PER_USD=83

# Optional: how long to retain dedupe keys (ms). Default 7 days.
# DEDUPE_PRUNE_MS=604800000

# Commerce — native WhatsApp product UI (future-ready): when catalog.json sets wa_product_id (Meta SKU),
# sendWhatsAppProductMessage is used if catalog_id resolves. Otherwise the same slot uses image_url (unchanged).
# Set WA_CATALOG_ID (recommended) OR WA_BUSINESS_ACCOUNT_ID (first linked catalog from Graph API; result is cached).
# Without catalog_id, items that only have wa_product_id still need image_url to appear in the carousel.
# WA_CATALOG_ID=
# WA_BUSINESS_ACCOUNT_ID=
# TEST_WHATSAPP_TO=15551234567
# TEST_PRODUCT_RETAILER_ID=
